{
  "name": "mece-studio",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "author": "Dann Bleeker Pedersen",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./scripts/build.mjs",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "lint": "biome check src tests",
    "format": "biome check --write src tests",
    "knip": "node ./node_modules/knip/bin/knip.js",
    "check:bundle-size": "node ./scripts/check-bundle-size.mjs",
    "check:features": "node ./scripts/check-feature-coverage.mjs",
    "stats": "node ./scripts/build-stats.mjs",
    "docs": "node ./scripts/build-docs.mjs",
    "icons": "node ./scripts/build-icons.mjs",
    "book": "node ./scripts/build-book.mjs",
    "book:epub": "node ./scripts/build-book-epub.mjs",
    "book:pdf": "node ./scripts/build-book-pdf.mjs",
    "verify": "node ./scripts/verify.mjs",
    "e2e": "node ./scripts/e2e.mjs"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@11.0.9",
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "dagre": "^0.8.5",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "nanoid": "^5.1.11",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/react": "^16.3.2",
    "@types/dagre": "^0.7.54",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.10.2",
    "jszip": "^3.10.1",
    "knip": "^6.14.2",
    "marked": "^16.4.2",
    "pdf-lib": "^1.17.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7",
    "workbox-window": "^7.4.1"
  }
}
